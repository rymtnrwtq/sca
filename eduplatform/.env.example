# .env.example
KINESCOPE_TOKEN=
APP_URL=
# ЮKassa — магазин в личном кабинете yookassa.ru → Настройки → Данные магазина
YUKASSA_SHOP_ID=
# Секретный ключ — yookassa.ru → Настройки → Ключи API
YUKASSA_SECRET_KEY=
JWT_SECRET=
DATABASE_URL=
# Установить username первого администратора (будет автоматически получать права при каждом запуске)
ADMIN_USERNAME=
# Telegram Bot Token — получить у @BotFather → /token
TELEGRAM_BOT_TOKEN=
# VAPID keys для Web Push — сгенерировать: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
